{
  "name": "@nebula/plugin-okx",
  "version": "0.1.0",
  "private": true,
  "description": "Nebula data plugin backed by OKX Onchain OS — yields, market data, and security scans",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@nebula/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
